{
  "name": "openvault-ai",
  "version": "0.0.1",
  "description": "AI assistant for note-aware chat, custom agents, and multiple model providers.",
  "license": "MIT",
  "author": "Or Shemtov",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs --production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "llm",
    "notes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/orshemtov/openvault-ai.git"
  },
  "bugs": {
    "url": "https://github.com/orshemtov/openvault-ai/issues"
  },
  "homepage": "https://github.com/orshemtov/openvault-ai#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "obsidian": "^1.12.3"
  }
}
